<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Monthly Budget</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: linear-gradient(135deg, #0a0a1a 0%, #0d1b2a 50%, #0a1628 100%); min-height: 100vh; font-family: 'DM Sans', sans-serif; color: #e8e8f0; }
input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;}
input[type=number]{-moz-appearance:textfield;}
.tab-btn{flex:1;padding:10px 0;border-radius:7px;border:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;transition:all 0.2s;}
.tx-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);margin-bottom:6px;}
.pill{display:inline-block;padding:2px 10px;border-radius:99px;font-size:11px;font-weight:600;}
button:disabled{opacity:0.5;cursor:not-allowed;}
select{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-family:inherit;font-size:12px;padding:4px 8px;outline:none;cursor:pointer;}
select option{background:#1a2540;}
.card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:16px 14px;text-align:center;}
.card-label{font-size:10px;color:#666;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:6px;}
.bar-bg{height:6px;background:rgba(255,255,255,0.07);border-radius:99px;overflow:hidden;margin-top:8px;}
.save-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:#4FCF8E;margin-left:6px;vertical-align:middle;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.3;}}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useRef } = React;

const CATEGORIES = [
{ id:“housing”,       label:“Housing & Utilities”,           icon:“🏠”, color:”#4F8EF7” },
{ id:“food”,          label:“Food & Groceries”,              icon:“🛒”, color:”#F7A44F” },
{ id:“transport”,     label:“Transport”,                     icon:“🚗”, color:”#4FCF8E” },
{ id:“entertainment”, label:“Entertainment & Subscriptions”, icon:“🎬”, color:”#B44FF7” },
{ id:“savings”,       label:“Savings & Investments”,         icon:“💰”, color:”#F7E44F” },
{ id:“health”,        label:“Health & Insurance”,            icon:“❤️”, color:”#F74F6A” },
{ id:“debt”,          label:“Debt Payments”,                 icon:“📋”, color:”#4FF7F0” },
{ id:“personal”,      label:“Personal & Misc”,               icon:“✨”, color:”#F74FB8” },
];
const MONTHS = [“January”,“February”,“March”,“April”,“May”,“June”,“July”,“August”,“September”,“October”,“November”,“December”];

function daysInMonth(m,y){return new Date(y,m+1,0).getDate();}
function fmt(v){return Number(v||0).toLocaleString(“en-US”,{minimumFractionDigits:2,maximumFractionDigits:2});}
function fmtInt(v){return Number(v||0).toLocaleString(“en-US”,{minimumFractionDigits:0,maximumFractionDigits:0});}
function parse(s){return parseFloat((s||””).toString().replace(/[^0-9.]/g,””))||0;}
function storageKey(m,y){return `budget_${y}_${m}`;}
function loadMonth(m,y){try{const r=localStorage.getItem(storageKey(m,y));return r?JSON.parse(r):null;}catch(e){return null;}}
function saveMonth(m,y,data){try{localStorage.setItem(storageKey(m,y),JSON.stringify(data));}catch(e){}}
function getAllMonths(){
const keys=[];for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k&&k.startsWith(“budget_”))keys.push(k);}
return keys.map(k=>{const[,y,m]=k.split(”_”);return{year:parseInt(y),month:parseInt(m),key:k};}).sort((a,b)=>b.year-a.year||b.month-a.month);
}

function DonutChart({budgets,transactions}){
const total=CATEGORIES.reduce((s,c)=>s+(budgets[c.id]||0),0);
if(!total)return <div style={{display:“flex”,alignItems:“center”,justifyContent:“center”,height:180,color:”#555”,fontSize:13}}>Add budget amounts to see chart</div>;
let cum=0;const r=70,cx=90,cy=90,sw=22,circ=2*Math.PI*r;
const segs=CATEGORIES.map(c=>{const val=budgets[c.id]||0,frac=val/total,dash=frac*circ,offset=circ-cum*circ;cum+=frac;return{…c,dash,offset,val};}).filter(s=>s.val>0);
const spent=CATEGORIES.reduce((s,c)=>s+transactions.filter(t=>t.category===c.id).reduce((a,t)=>a+t.amount,0),0);
const pct=Math.min(100,Math.round((spent/total)*100));
return(
<div style={{position:“relative”,width:180,height:180,flexShrink:0}}>
<svg width={180} height={180} style={{transform:“rotate(-90deg)”}}>
<circle cx={cx} cy={cy} r={r} fill="none" stroke="#1a1a2e" strokeWidth={sw}/>
{segs.map(s=><circle key={s.id} cx={cx} cy={cy} r={r} fill=“none” stroke={s.color} strokeWidth={sw} strokeDasharray={`${s.dash} ${circ-s.dash}`} strokeDashoffset={s.offset}/>)}
</svg>
<div style={{position:“absolute”,inset:0,display:“flex”,flexDirection:“column”,alignItems:“center”,justifyContent:“center”}}>
<div style={{fontSize:22,fontWeight:800,color:”#fff”}}>{pct}%</div>
<div style={{fontSize:10,color:”#888”,letterSpacing:“0.08em”,textTransform:“uppercase”}}>used</div>
</div>
</div>
);
}

function MiniBar({value,max,color}){
const pct=max>0?Math.min(100,(value/max)*100):0;
return <div className="bar-bg"><div style={{height:“100%”,borderRadius:99,background:color,width:`${pct}%`,transition:“width 0.4s”}}/></div>;
}

function App(){
const now=new Date();
const [month,setMonth]=useState(now.getMonth());
const [year,setYear]=useState(now.getFullYear());
const [income,setIncome]=useState(””);
const [budgets,setBudgets]=useState({});
const [transactions,setTransactions]=useState([]);
const [tab,setTab]=useState(“budget”);
const [manualDesc,setManualDesc]=useState(””);
const [manualAmt,setManualAmt]=useState(””);
const [manualCat,setManualCat]=useState(“food”);
const [manualDate,setManualDate]=useState(now.toISOString().split(“T”)[0]);
const [savedAt,setSavedAt]=useState(null);

useEffect(()=>{
const data=loadMonth(month,year);
if(data){setIncome(data.income||””);setBudgets(data.budgets||{});setTransactions(data.transactions||[]);}
else{setIncome(””);setBudgets({});setTransactions([]);}
setSavedAt(null);
},[month,year]);

useEffect(()=>{
const timer=setTimeout(()=>{saveMonth(month,year,{income,budgets,transactions});setSavedAt(new Date());},600);
return()=>clearTimeout(timer);
},[income,budgets,transactions,month,year]);

const days=daysInMonth(month,year);
const daysPassed=(now.getMonth()===month&&now.getFullYear()===year)?now.getDate():days;
const spentByCat={};
CATEGORIES.forEach(c=>{spentByCat[c.id]=transactions.filter(t=>t.category===c.id).reduce((s,t)=>s+t.amount,0);});
const totalBudgeted=CATEGORIES.reduce((s,c)=>s+(budgets[c.id]||0),0);
const totalSpent=Object.values(spentByCat).reduce((a,b)=>a+b,0);
const incomeNum=parse(income);
const unallocated=incomeNum-totalBudgeted;
const leftover=totalBudgeted-totalSpent;
const dailyAvg=daysPassed>0?totalSpent/daysPassed:0;
const projected=dailyAvg*days;
const overBudget=CATEGORIES.filter(c=>spentByCat[c.id]>(budgets[c.id]||0)&&(budgets[c.id]||0)>0);

function prevMonth(){if(month===0){setMonth(11);setYear(y=>y-1);}else setMonth(m=>m-1);}
function nextMonth(){if(month===11){setMonth(0);setYear(y=>y+1);}else setMonth(m=>m+1);}

function addManual(){
if(!manualAmt||!manualDesc)return;
setTransactions(prev=>[…prev,{id:Date.now(),description:manualDesc,amount:parse(manualAmt),category:manualCat,date:manualDate,source:“manual”}]);
setManualDesc(””);setManualAmt(””);
}

const catColor=id=>CATEGORIES.find(c=>c.id===id)?.color||”#888”;
const catIcon=id=>CATEGORIES.find(c=>c.id===id)?.icon||”•”;
const catLabel=id=>CATEGORIES.find(c=>c.id===id)?.label||id;
const sortedTx=[…transactions].sort((a,b)=>new Date(b.date)-new Date(a.date));
const allMonths=getAllMonths();

return(
<div style={{minHeight:“100vh”,paddingBottom:60}}>
{/* Header */}
<div style={{background:“linear-gradient(180deg,rgba(79,142,247,0.12) 0%,transparent 100%)”,borderBottom:“1px solid rgba(255,255,255,0.06)”,padding:“32px 24px 24px”}}>
<div style={{maxWidth:720,margin:“0 auto”}}>
<div style={{display:“flex”,alignItems:“center”,justifyContent:“space-between”,flexWrap:“wrap”,gap:12}}>
<div>
<div style={{fontSize:11,letterSpacing:“0.15em”,textTransform:“uppercase”,color:”#4F8EF7”,marginBottom:4}}>
Monthly Budget
{savedAt&&<span className="save-dot" title="Saved"/>}
</div>
<h1 style={{fontSize:32,fontWeight:700,color:”#fff”,fontFamily:”‘DM Serif Display’,serif”}}>{MONTHS[month]} {year}</h1>
</div>
<div style={{display:“flex”,gap:8}}>
<button onClick={prevMonth} style={{background:“rgba(255,255,255,0.07)”,border:“1px solid rgba(255,255,255,0.1)”,borderRadius:8,color:”#fff”,width:36,height:36,cursor:“pointer”,fontSize:16}}>‹</button>
<button onClick={nextMonth} style={{background:“rgba(255,255,255,0.07)”,border:“1px solid rgba(255,255,255,0.1)”,borderRadius:8,color:”#fff”,width:36,height:36,cursor:“pointer”,fontSize:16}}>›</button>
</div>
</div>
<div style={{marginTop:20,background:“rgba(255,255,255,0.04)”,borderRadius:12,border:“1px solid rgba(255,255,255,0.08)”,padding:“14px 20px”,display:“flex”,alignItems:“center”,gap:16,flexWrap:“wrap”}}>
<div style={{fontSize:12,color:”#888”,textTransform:“uppercase”,letterSpacing:“0.1em”}}>Income</div>
<div style={{display:“flex”,alignItems:“center”,gap:8,flex:1}}>
<span style={{color:”#4FCF8E”,fontSize:18,fontWeight:600}}>$</span>
<input type=“number” placeholder=“Enter monthly income” value={income} onChange={e=>setIncome(e.target.value)}
style={{background:“transparent”,border:“none”,outline:“none”,color:”#fff”,fontSize:18,fontWeight:600,fontFamily:“inherit”,width:“100%”,minWidth:120}}/>
</div>
{incomeNum>0&&<div style={{fontSize:13,color:unallocated<0?”#F74F6A”:”#4FCF8E”,fontWeight:600}}>{unallocated<0?`⚠ Over by $${fmtInt(Math.abs(unallocated))}`:`$${fmtInt(unallocated)} unallocated`}</div>}
</div>
</div>
</div>

