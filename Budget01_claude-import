                    <div style={{display:"flex",gap:20}}>
                      {mIncome>0&&<div style={{textAlign:"right"}}>
                        <div style={{fontSize:10,color:"#555",textTransform:"uppercase",letterSpacing:"0.08em"}}>Income</div>
                        <div style={{fontSize:14,fontWeight:600,color:"#4FCF8E"}}>${fmtInt(mIncome)}</div>
                      </div>}
                      <div style={{textAlign:"right"}}>
                        <div style={{fontSize:10,color:"#555",textTransform:"uppercase",letterSpacing:"0.08em"}}>Spent</div>
                        <div style={{fontSize:14,fontWeight:600,color:"#F7A44F"}}>${fmtInt(mSpent)}</div>
                      </div>
                      {mBudgeted>0&&<div style={{textAlign:"right"}}>
                        <div style={{fontSize:10,color:"#555",textTransform:"uppercase",letterSpacing:"0.08em"}}>Budget</div>
                        <div style={{fontSize:14,fontWeight:600,color:over?"#F74F6A":"#4FCF8E"}}>{Math.round(pct)}%</div>
                      </div>}
                    </div>
                  </div>
                  {mBudgeted>0&&<div style={{marginTop:12}}><MiniBar value={mSpent} max={mBudgeted} color={over?"#F74F6A":"#4FCF8E"}/></div>}
                  <div style={{display:"flex",gap:6,marginTop:12,flexWrap:"wrap"}}>
                    {CATEGORIES.map(c=>{
                      const cs=mTx.filter(t=>t.category===c.id).reduce((s,t)=>s+t.amount,0);
                      if(!cs)return null;
                      return <span key={c.id} className="pill" style={{background:c.color+"18",color:c.color}}>{c.icon} ${fmtInt(cs)}</span>;
                    })}
                  </div>
                </div>
              );
            })}
          </>
        }
      </div>
    )}
  </div>
